{
  "servers": {
    "percival-vision-mcp": {
      "enabled": true,
      "command": "uv",
      "args": [
        "run",
        "--no-sync",
        "--directory",
        "/absolute/path/to/percival.OS_Dev/mcp_servers/percival_vision_mcp",
        "python",
        "main.py",
        "--mode",
        "stdio"
      ],
      "description": "Percival Vision MCP server (FastMCP + structured contract)",
      "toolTimeout": 45,
      "env": {
        "UV_PROJECT_ENVIRONMENT": "/absolute/path/to/percival.OS_Dev/.venv",
        "PERCIVAL_API_KEY": "your-api-key-here",
        "PERCIVAL_BASE_URL": "https://api.venice.ai/api/v1",
        "PERCIVAL_DEFAULT_MODEL": "qwen-2.5-vl",
        "PERCIVAL_VISION_MCP_ALLOWED_ROOTS": "/absolute/path/to/percival.OS_Dev",
        "PERCIVAL_VISION_MCP_WORKING_DIR_MODE": "compat"
      }
    }
  }
}
